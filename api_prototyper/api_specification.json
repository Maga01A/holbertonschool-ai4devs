{
  "openapi": "3.0.3",
  "info": { "title": "EcoRide Enterprise API", "version": "1.0.0" },
  "components": {
    "securitySchemes": { "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" } },
    "schemas": {
      "User": { "type": "object", "properties": { "id": { "type": "string" }, "username": { "type": "string" } } },
      "Error": { "type": "object", "properties": { "status": { "type": "integer" }, "message": { "type": "string" } } }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/users": {
      "post": { "summary": "Create user", "responses": { "201": { "description": "Created" }, "400": { "description": "Bad Request" } } }
    },
    "/rides": {
      "get": { "parameters": [{ "name": "page", "in": "query", "schema": { "type": "integer" } }], "responses": { "200": { "description": "OK" }, "401": { "description": "Unauthorized" } } },
      "post": { "responses": { "201": { "description": "Created" }, "400": { "description": "Bad Request" } } }
    },
    "/rides/{id}": {
      "get": { "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "OK" }, "404": { "description": "Not Found" } } },
      "put": { "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "OK" }, "403": { "description": "Forbidden" } } },
      "delete": { "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "204": { "description": "Deleted" } } }
    }
  }
}
