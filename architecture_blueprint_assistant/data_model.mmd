erDiagram
    USER ||--o{ RIDE : "requests"
    DRIVER ||--o{ RIDE : "fulfills"
    RIDE ||--|| PAYMENT : "generates"
    RIDE ||--o{ ECO_IMPACT : "calculates"
    VEHICLE ||--o{ RIDE : "is used in"

    USER {
        string user_id PK
        string full_name
        string email
        int loyalty_points
    }
    DRIVER {
        string driver_id PK
        string license_number
        string rating
    }
    RIDE {
        string ride_id PK
        string rider_id FK
        string driver_id FK
        string vehicle_id FK
        string status
        datetime created_at
    }
    PAYMENT {
        string payment_id PK
        string ride_id FK
        decimal amount
        string status
    }
    ECO_IMPACT {
        string impact_id PK
        string ride_id FK
        decimal co2_saved_kg
        decimal distance_km
    }
